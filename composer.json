{
    "name": "ctg/php-db",
    "description": "Minimal PDO database library with fold/accumulator pattern",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "CTG\\DB\\": "src/",
            "CTG\\Test\\": "lib/ctg-php-test/src/",
            "CTG\\FnProg\\": "lib/ctg-php-fnprog/src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    }
